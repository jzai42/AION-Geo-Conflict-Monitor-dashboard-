# Required to run `.github/scripts/generate-aion-daily.mjs` locally (CI uses repo secret GEMINI_API_KEY).
# 主模型默认与 CI 一致：Gemini 3 Flash Preview（https://ai.google.dev/gemini-api/docs/gemini-3）
# GEMINI_MODEL=gemini-3-flash-preview
# 若需切换到 3.1 Flash-Lite：GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_API_KEY=

# 仅走 OpenAI Responses API + web_search 生成日报（不调用 Gemini）：AION_USE_OPENAI_WEBSEARCH=1
# 需 OPENAI_API_KEY；可选 OPENAI_WEBSEARCH_MODEL=gpt-4.1（以 OpenAI 控制台为准）
# AION_USE_OPENAI_WEBSEARCH=1
# OPENAI_API_KEY=
# OPENAI_WEBSEARCH_MODEL=gpt-4.1

# Chat Completions 兜底 / 旧逻辑用（与 web_search 模型可不同）
# OPENAI_MODEL=gpt-4.1-mini

# APP_URL: Optional. The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# 前端构建时写入：生产环境若 API 与静态站不同源，填完整 API 根 URL（无尾斜杠）
# VITE_API_BASE=https://your-api.example.com

# 复制链接 / 系统分享使用的固定短链（无 query，无尾斜杠）；不设则默认 https://qz-l.com/Q54ahm
# VITE_SHARE_COPY_URL=https://qz-l.com/Q54ahm

# PDF API（仅本地/服务端）：监听端口与 Chrome 路径
# PDF_API_PORT=8787
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
