{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,pdf -c cyan,magenta \"vite --port=3000 --host=0.0.0.0\" \"tsx server/index.ts\"",
    "dev:client": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "tsx server/index.ts",
    "dev:all": "npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "clean:pdf": "node scripts/clean-generated-pdfs.mjs",
    "lint": "tsc --noEmit",
    "verify:pdf": "node scripts/verify-pdf-api.mjs",
    "verify:pdf:full": "VERIFY_PDF_FULL=1 node scripts/verify-pdf-api.mjs",
    "docker:build": "docker build -t aion-pdf-api .",
    "docker:up": "docker compose up --build -d"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "puppeteer-core": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
